generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  donor
  ngo
  volunteer
}

enum ItemStatus {
  listed
  matched
  pickup_scheduled
  delivered
}

enum ItemCategory {
  clothes
  books
  food
  electronics
  furniture
  other
}

enum PickupStatus {
  pending
  confirmed
  completed
  cancelled
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  role      Role
  phone     String?
  city      String?
  createdAt DateTime @default(now())

  // Relations
  donatedItems  Item[]    @relation("DonorItems")
  ngo           NGO?
  pickups       Pickup[]  @relation("VolunteerPickups")
}

model Item {
  id          String       @id @default(uuid())
  title       String
  description String
  category    ItemCategory
  imageUrl    String?
  status      ItemStatus   @default(listed)
  createdAt   DateTime     @default(now())

  // Relations
  donor         User          @relation("DonorItems", fields: [donorId], references: [id])
  donorId       String
  pickup        Pickup?
  impactReport  ImpactReport?
}

model NGO {
  id                 String         @id @default(uuid())
  orgName            String
  description        String?
  location           String
  acceptedCategories ItemCategory[]
  isVerified         Boolean        @default(false)
  rating             Float          @default(0)

  // Relations
  user     User     @relation(fields: [userId], references: [id])
  userId   String   @unique
  pickups  Pickup[]
}

model Pickup {
  id            String       @id @default(uuid())
  scheduledTime DateTime?
  status        PickupStatus @default(pending)
  notes         String?
  createdAt     DateTime     @default(now())

  // Relations
  item        Item     @relation(fields: [itemId], references: [id])
  itemId      String   @unique
  ngo         NGO      @relation(fields: [ngoId], references: [id])
  ngoId       String
  volunteer   User?    @relation("VolunteerPickups", fields: [volunteerId], references: [id])
  volunteerId String?
}

model ImpactReport {
  id          String   @id @default(uuid())
  reportText  String
  generatedAt DateTime @default(now())

  // Relations
  item   Item   @relation(fields: [itemId], references: [id])
  itemId String @unique
}